---
import { logos, MODULES, SECTIONS } from "../lib/content";
import { BRAND_NAME } from "@artificio/ui/static";
import SiteHeaderIsland from "./SiteHeaderIsland";
interface Props {
  currentHref?: string;
}
const { currentHref } = Astro.props;
---
<header class="artificio-header" data-sticky="true">
  <div class="artificio-header-main">
    <a class="artificio-brand" href="/">
      <img class="artificio-brand-logo logo-navy" src={logos.logoNavy} alt={BRAND_NAME} width="300" height="100" />
      <img class="artificio-brand-logo logo-neg" src={logos.logoNeg} alt={BRAND_NAME} width="300" height="100" />
    </a>
    <nav aria-label="Projetos do Artifício">
      <ul class="artificio-nav-list">
        {MODULES.map((m) => (
          <li>
            <a
              class="artificio-nav-link"
              href={m.href}
              aria-current={m.label === "Portal" ? "page" : undefined}
            >{m.label}</a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="artificio-session" aria-live="polite">
      <SiteHeaderIsland client:idle />
    </div>
  </div>
  <nav class="artificio-subnav" aria-label="Seções do blog">
    <ul class="artificio-nav-list">
      {SECTIONS.map((s) => (
        <li>
          <a
            class="artificio-nav-link"
            href={s.href}
            aria-current={currentHref === s.href ? "page" : undefined}
          >{s.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>
