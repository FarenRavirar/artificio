---
// Etapa 1: footer .astro hub reusando CSS @artificio/ui + marca. Etapa 2: <Footer /> React server-render.
import { logos, MODULES } from "../lib/content";
const year = 2026;
---
<footer class="artificio-footer">
  <div class="artificio-footer-inner">
    <div class="artificio-footer-brand-col">
      <a class="artificio-footer-brand-link" href="/">
        <img class="artificio-footer-logo logo-navy" src={logos.logoNavy} alt="Artifício RPG" width="300" height="100" />
        <img class="artificio-footer-logo logo-neg" src={logos.logoNeg} alt="Artifício RPG" width="300" height="100" />
      </a>
      <p class="artificio-footer-tagline">Hub de projetos de RPG em português. Gratuito, sem anúncios, sem coleta desnecessária.</p>
    </div>
    <nav class="artificio-footer-nav" aria-label="Projetos do Artifício">
      <span class="artificio-footer-nav-title">Projetos</span>
      <ul class="artificio-footer-nav-list">
        {MODULES.map((m) => (
          <li><a class="artificio-footer-nav-link" href={m.href}>{m.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
  <p class="artificio-footer-gift">Este é um presente da Artifício RPG para toda a comunidade brasileira de RPG. Compartilhe com seus grupos!</p>
  <p class="artificio-footer-copyright-summary">
    Artifício RPG © {year}. Todos os direitos reservados. Leitura, citação curta e compartilhamento de links são permitidos com crédito e link para a fonte. Reprodução integral, espelhamento, raspagem e uso comercial dependem de autorização prévia.
    <a href="/termos-de-uso-e-direitos-autorais/">Ver termos de uso e direitos autorais</a>.
  </p>
  <div class="artificio-footer-base">
    <span class="artificio-footer-brand">Artifício RPG</span>
    <span>© {year} · artificiorpg.com</span>
  </div>
</footer>
