---
import Base from "../../../layouts/Base.astro";
import Card from "../../../components/Card.astro";
import { allCategories, postsByCat, catName } from "../../../lib/content";

export function getStaticPaths() {
  return allCategories().map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const list = postsByCat(slug as string);
const name = catName(slug as string);
const canonical = `https://artificiorpg.com/blog/categoria/${slug}/`;
---
<Base
  title={`${name} — Blog Artifício RPG`}
  canonical={canonical}
  description={`Artigos de RPG na categoria ${name}.`}
>
  <main class="container">
    <nav class="breadcrumb" aria-label="Trilha">
      <a href="/">Início</a> <span>/</span> <a href="/blog/">Blog</a> <span>/</span> <span>{name}</span>
    </nav>
    <header class="archive-head">
      <span class="kicker">Categoria</span>
      <h1>{name}</h1>
      <p class="archive-count">{list.length} artigo{list.length === 1 ? "" : "s"}</p>
    </header>
    <section class="grid">{list.map((p) => <Card post={p} />)}</section>
  </main>
</Base>
