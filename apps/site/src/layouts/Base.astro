---
import "../styles/global.css";
import { buildMeta, renderJsonLd, SITE } from "@artificio/content";
import { faviconV2 } from "@artificio/ui/static";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SearchModal from "../components/SearchModal.astro";
import Analytics from "../components/Analytics.astro";
import FeedbackWidget from "../components/FeedbackWidget.astro";

interface Props {
  title: string;
  description?: string;
  canonical: string;
  ogType?: "website" | "article";
  image?: string;
  ogTitle?: string;
  ogDescription?: string;
  twitterCard?: string;
  noindex?: boolean;
  jsonld?: object | object[];
  currentHref?: string;
}
const {
  title,
  description = SITE.description,
  canonical,
  ogType = "website",
  image,
  ogTitle,
  ogDescription,
  twitterCard,
  noindex = false,
  jsonld,
  currentHref,
} = Astro.props;

const metaTags = buildMeta({ title, description, canonical, type: ogType, image, ogTitle, ogDescription, twitterCard, noindex });
const lds = jsonld ? (Array.isArray(jsonld) ? jsonld : [jsonld]) : [];
---
<!doctype html>
<html lang="pt-BR" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type={faviconV2.type} href={faviconV2.src} />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    {metaTags.map((m) => (m.name ? <meta name={m.name} content={m.content} /> : <meta property={m.property} content={m.content} />))}
    <link rel="alternate" type="application/rss+xml" title="Artifício RPG — Blog" href="/rss.xml" />
    {lds.map((ld) => <script type="application/ld+json" set:html={renderJsonLd(ld)} />)}
    <Analytics />
    <script is:inline>
      (function () {
        try {
          function readCookie(name) {
            var prefix = name + "=";
            var parts = document.cookie.split(";");
            for (var i = 0; i < parts.length; i++) {
              var value = parts[i].trim();
              if (value.indexOf(prefix) === 0) return decodeURIComponent(value.slice(prefix.length));
            }
            return null;
          }
          var t = readCookie("artificio_theme") || localStorage.getItem("theme") ||
            (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
          document.documentElement.dataset.theme = t;
        } catch (e) {}
      })();
    </script>
    <script is:inline>
      /* Diagnóstico do widget de feedback (Spec 021): captura cedo console/rede em buffer
         global. Só url/método/status (sem corpo/headers/tokens). Vanilla — não quebra zero-JS. */
      (function () {
        var CAP = 30, MAX = 500;
        var d = { console: [], network: [] };
        window.__afFeedbackDiag = d;
        function push(buf, e) { buf.push(e); if (buf.length > CAP) buf.splice(0, buf.length - CAP); }
        function tr(s) { return String(s).length > MAX ? String(s).slice(0, MAX) : String(s); }
        function rec(level, msg) { var m = String(msg).trim(); if (m) push(d.console, { level: level, message: tr(m), ts: new Date().toISOString() }); }
        var oe = console.error.bind(console), ow = console.warn.bind(console);
        console.error = function () { rec("error", Array.prototype.join.call(arguments, " ")); oe.apply(null, arguments); };
        console.warn = function () { rec("warn", Array.prototype.join.call(arguments, " ")); ow.apply(null, arguments); };
        window.addEventListener("error", function (ev) { rec("window.onerror", ev.message || "Erro desconhecido"); });
        window.addEventListener("unhandledrejection", function (ev) { rec("unhandledrejection", ev.reason && ev.reason.message ? ev.reason.message : String(ev.reason)); });
        if (typeof window.fetch === "function") {
          var of = window.fetch.bind(window);
          window.fetch = function (input, init) {
            var method = (init && init.method) || "GET";
            var url = typeof input === "string" ? input : (input && input.url) || String(input);
            return of(input, init).then(function (r) {
              if (r.status >= 400) push(d.network, { url: tr(url), method: String(method).toUpperCase(), status: r.status, ts: new Date().toISOString() });
              return r;
            }).catch(function (err) { push(d.network, { url: tr(url), method: String(method).toUpperCase(), status: 0, ts: new Date().toISOString() }); throw err; });
          };
        }
      })();
    </script>
  </head>
  <body>
    <SiteHeader currentHref={currentHref} />
    <slot />
    <SiteFooter />
    <SearchModal />
    <FeedbackWidget />
    <script is:inline>
      (function () {
        var links = Array.prototype.slice.call(document.querySelectorAll(".toc a"));
        if (links.length) {
          var io = new IntersectionObserver(function (es) {
            es.forEach(function (e) {
              if (e.isIntersecting) {
                links.forEach(function (l) {
                  l.classList.toggle("active", l.getAttribute("href") === "#" + e.target.id);
                });
              }
            });
          }, { rootMargin: "-10% 0px -80% 0px" });
          document.querySelectorAll("article h2[id], article h3[id]").forEach(function (h) { io.observe(h); });
        }
      })();
    </script>
  </body>
</html>
