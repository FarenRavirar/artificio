---
import "../styles/global.css";
import { buildMeta, renderJsonLd, SITE } from "@artificio/content";
import { faviconV2 } from "@artificio/ui";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SearchModal from "../components/SearchModal.astro";
import Analytics from "../components/Analytics.astro";

interface Props {
  title: string;
  description?: string;
  canonical: string;
  ogType?: "website" | "article";
  image?: string;
  ogTitle?: string;
  ogDescription?: string;
  twitterCard?: string;
  noindex?: boolean;
  jsonld?: object | object[];
  currentHref?: string;
}
const {
  title,
  description = SITE.description,
  canonical,
  ogType = "website",
  image,
  ogTitle,
  ogDescription,
  twitterCard,
  noindex = false,
  jsonld,
  currentHref,
} = Astro.props;

const metaTags = buildMeta({ title, description, canonical, type: ogType, image, ogTitle, ogDescription, twitterCard, noindex });
const lds = jsonld ? (Array.isArray(jsonld) ? jsonld : [jsonld]) : [];
---
<!doctype html>
<html lang="pt-BR" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type={faviconV2.type} href={faviconV2.src} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    {metaTags.map((m) => (m.name ? <meta name={m.name} content={m.content} /> : <meta property={m.property} content={m.content} />))}
    <link rel="alternate" type="application/rss+xml" title="Artifício RPG — Blog" href="/rss.xml" />
    {lds.map((ld) => <script type="application/ld+json" set:html={renderJsonLd(ld)} />)}
    <Analytics />
    <script is:inline>
      (function () {
        try {
          function readCookie(name) {
            var prefix = name + "=";
            var parts = document.cookie.split(";");
            for (var i = 0; i < parts.length; i++) {
              var value = parts[i].trim();
              if (value.indexOf(prefix) === 0) return decodeURIComponent(value.slice(prefix.length));
            }
            return null;
          }
          var t = readCookie("artificio_theme") || localStorage.getItem("theme") ||
            (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
          document.documentElement.dataset.theme = t;
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <SiteHeader currentHref={currentHref} />
    <slot />
    <SiteFooter />
    <SearchModal />
    <script is:inline>
      (function () {
        function applyVariant(t) {
          var v = t === "dark" ? "dark" : "light";
          document.querySelectorAll(".artificio-header, .artificio-footer").forEach(function (el) {
            if (v === "dark") el.setAttribute("data-variant", "dark");
            else el.removeAttribute("data-variant");
          });
        }
        function updateLoginLink(t) {
          var link = document.getElementById("site-login-link");
          if (!link) return;
          if (link.getAttribute("data-authenticated") === "true") return;
          try {
            var url = new URL(link.getAttribute("href") || "https://accounts.artificiorpg.com/login");
            url.searchParams.set("return", window.location.href);
            var v = t === "dark" ? "dark" : "light";
            url.searchParams.set("theme", v);
            link.setAttribute("href", url.toString());
          } catch (e) {}
        }
        function writeThemeCookie(t) {
          var v = t === "dark" ? "dark" : "light";
          document.cookie = "artificio_theme=" + v + "; Path=/; Domain=.artificiorpg.com; Max-Age=31536000; SameSite=Lax; Secure";
        }
        function readUserRole(value) {
          if (!value || typeof value !== "object" || !("user" in value)) return null;
          var user = value.user;
          if (!user || typeof user !== "object" || !("role" in user)) return null;
          return user.role === "admin" || user.role === "user" ? user.role : null;
        }
        function updateSessionLink() {
          var link = document.getElementById("site-login-link");
          if (!link) return;
          var ACC = "https://accounts.artificiorpg.com";
          function getMe() { return fetch(ACC + "/api/auth/me", { credentials: "include" }); }
          getMe()
            .then(function (res) {
              if (res.ok) return res;
              // Access (15min) expirado: tenta refresh (cookie 7d) e repete o /me — login persiste.
              return fetch(ACC + "/api/auth/refresh", { credentials: "include" })
                .then(function (r) { return r.ok ? getMe() : res; });
            })
            .then(function (res) {
              if (!res || !res.ok) return null;
              return res.json();
            })
            .then(function (body) {
              var role = readUserRole(body);
              if (!role) return;
              link.setAttribute("data-authenticated", "true");
              if (role === "admin") {
                link.textContent = "Admin";
                link.setAttribute("href", "/admin/");
                link.setAttribute("title", "Abrir área administrativa");
              } else {
                link.textContent = "Conta";
                link.setAttribute("href", "https://accounts.artificiorpg.com/login?return=" + encodeURIComponent(window.location.href));
                link.setAttribute("title", "Sessão Artifício ativa");
              }
            })
            .catch(function () {});
        }
        applyVariant(document.documentElement.dataset.theme);
        updateLoginLink(document.documentElement.dataset.theme);
        writeThemeCookie(document.documentElement.dataset.theme);
        updateSessionLink();
        var btn = document.getElementById("theme-toggle");
        if (btn) btn.addEventListener("click", function () {
          var r = document.documentElement;
          var t = r.dataset.theme === "dark" ? "light" : "dark";
          r.dataset.theme = t;
          applyVariant(t);
          updateLoginLink(t);
          writeThemeCookie(t);
          try { localStorage.setItem("theme", t); } catch (e) {}
        });
        var links = Array.prototype.slice.call(document.querySelectorAll(".toc a"));
        if (links.length) {
          var io = new IntersectionObserver(function (es) {
            es.forEach(function (e) {
              if (e.isIntersecting) {
                links.forEach(function (l) {
                  l.classList.toggle("active", l.getAttribute("href") === "#" + e.target.id);
                });
              }
            });
          }, { rootMargin: "-10% 0px -80% 0px" });
          document.querySelectorAll("article h2[id], article h3[id]").forEach(function (h) { io.observe(h); });
        }
      })();
    </script>
  </body>
</html>
