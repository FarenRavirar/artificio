---
import { defaultNavItems } from "@artificio/ui/modules";
import { REGRAS_SECTIONS } from "../data/regras";
import type { CategoryBlock } from "../lib/groups-source";

interface Props {
  categories: CategoryBlock[];
}
const { categories } = Astro.props;
---
<aside class="sidebar">
  <details class="nav-group" open>
    <summary>Grupos<span class="chevron">›</span></summary>
    <nav class="nav-sub">
      {categories.map((c) => <a href={`#cat-${c.id}`}>{c.title}</a>)}
    </nav>
  </details>

  <a class="nav-solo" href="#comunidade">Grupos de RPG</a>

  <details class="nav-group">
    <summary>Regras<span class="chevron">›</span></summary>
    <nav class="nav-sub">
      {REGRAS_SECTIONS.map((s) => <a href={`#regra-${s.id}`}>{s.title}</a>)}
    </nav>
  </details>

  <details class="nav-group">
    <summary>Projetos<span class="chevron">›</span></summary>
    <nav class="nav-sub">
      {defaultNavItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
  </details>
</aside>
