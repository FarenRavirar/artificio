# Servidor
PORT=3000
NODE_ENV=development

# Banco de Dados PostgreSQL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/mesas_rpg

# SSO central (accounts.artificiorpg.com)
ACCOUNTS_URL=https://accounts.artificiorpg.com

# Autenticação JWT compartilhada
# Usar o MESMO JWT_SECRET do accounts. Placeholder sem valor real.
JWT_SECRET=mesmo_jwt_secret_do_accounts

# Frontend URL (fallback principal para redirect após OAuth)
FRONTEND_URL=http://localhost:5173

# Frontend URLs permitidas (CSV) para CORS e redirect OAuth seguro
# Exemplo: FRONTEND_URLS=https://mesasbeta.artificiorpg.com,http://localhost:5173
FRONTEND_URLS=

# Imgur API (para upload de imagens)
IMGUR_CLIENT_ID=seu_imgur_client_id_aqui

# Discord OAuth (integração perfil mestre; separado do login SSO)
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
DISCORD_GUILD_ID=your_discord_guild_id_here
DISCORD_REDIRECT_URI=https://mesasbeta.artificiorpg.com/auth/discord/callback

# Cloudinary (upload de imagens)
CLOUDINARY_CLOUD_NAME=seu_cloud_name_aqui
CLOUDINARY_API_KEY=seu_api_key_aqui
CLOUDINARY_API_SECRET=seu_api_secret_aqui
