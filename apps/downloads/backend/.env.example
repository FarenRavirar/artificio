# Servidor
PORT=3000
NODE_ENV=development

# Banco de Dados PostgreSQL (schema isolado proprio do app — regra de isolamento por app/projeto)
DATABASE_URL=postgresql://usuario:senha@localhost:5432/downloads_rpg

# SSO central (accounts.artificiorpg.com)
ACCOUNTS_URL=https://accounts.artificiorpg.com

# Autenticacao JWT compartilhada
# Usar o MESMO JWT_SECRET do accounts. Placeholder sem valor real.
JWT_SECRET=mesmo_jwt_secret_do_accounts

# Frontend URL (fallback principal para redirect apos OAuth)
FRONTEND_URL=http://localhost:5174
PUBLIC_SITE_URL=https://downloads.artificiorpg.com

# Frontend URLs permitidas (CSV) para CORS
# Exemplo: FRONTEND_URLS=https://downloadsbeta.artificiorpg.com,http://localhost:5174
FRONTEND_URLS=

# Catalogo central (spec 062, apps/site) — consumido via @artificio/catalog-client
CATALOG_API_URL=https://artificiorpg.com
CATALOG_INTERNAL_TOKEN=

# Storage multi-provider (spec 071): ordem fixa R2 -> B2 -> Fastio -> Cloudinary (D091).
# Cloudinary reusa CLOUDINARY_* ja configurado via @artificio/media, sem entrada propria aqui.

# Cloudflare R2 (primario) — compativel S3
# REGRA PETREA: free tier real = 10GB / 1M ops Classe A / 10M ops Classe B por mes.
# Se as vars *_QUOTA_* abaixo ficarem vazias, o codigo usa default de 90% do free
# tier (9GiB / 900k / 9M) — NUNCA subir estes valores para perto do limite real,
# o risco de cobranca deve ficar sempre em zero (decisao do mantenedor).
R2_ENDPOINT=
R2_REGION=auto
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=
R2_QUOTA_BYTES=
R2_QUOTA_CLASS_A_OPS=
R2_QUOTA_CLASS_B_OPS=

# Backblaze B2 (fallback por cota) — compativel S3
B2_ENDPOINT=
B2_REGION=
B2_BUCKET=
B2_ACCESS_KEY_ID=
B2_SECRET_ACCESS_KEY=
B2_PUBLIC_BASE_URL=
B2_QUOTA_BYTES=
B2_QUOTA_CLASS_A_OPS=
B2_QUOTA_CLASS_B_OPS=

# Fastio (fast.io) — 3o fallback, REST proprio (T0.1: confirmar contrato real antes do 1o deploy)
FASTIO_API_BASE_URL=
FASTIO_API_KEY=
FASTIO_BUCKET=
FASTIO_PUBLIC_BASE_URL=
FASTIO_QUOTA_BYTES=
