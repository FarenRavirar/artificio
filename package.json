{
  "name": "artificio",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "quality:lighthouse": "node scripts/quality/lighthouse-harness.mjs",
    "smoke:ingress-realip": "node scripts/ci/check_ingress_realip_contract.mjs",
    "test": "turbo run test",
    "api:inventory": "tsx scripts/api/inventory.ts",
    "api:inventory:tests": "tsx scripts/api/inventory.ts --include-tests",
    "api:consumers": "tsx scripts/api/consumers.ts",
    "api:consumers:tests": "tsx scripts/api/consumers.ts --include-tests",
    "api:lint": "tsx scripts/api/lint-openapi.ts",
    "api:generate-openapi": "tsx scripts/api/generate-openapi.ts",
    "api:check": "tsx scripts/api/check-api.ts",
    "api:traffic": "tsx scripts/api/traffic.ts",
    "api:diff": "tsx scripts/api/diff-api.ts",
    "api:docs": "tsx scripts/api/build-docs.ts",
    "verify:api": "tsx scripts/api/verify-api.ts",
    "verify:api:full": "tsx scripts/api/verify-api.ts --full",
    "prepare": "node scripts/git-hooks/install-hooks.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@redocly/cli": "^2.35.1",
    "@types/express": "^5.0.3",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "js-yaml": "^5.2.0",
    "lighthouse": "^13.4.0",
    "openapi-diff": "^0.24.1",
    "tsx": "4.22.4",
    "turbo": "^2.9.18",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^3.2.2"
  },
  "engines": {
    "node": ">=24"
  }
